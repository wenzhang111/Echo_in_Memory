# ================== Ollama 本地模型 ==================
# 使用的 Ollama 模型名称（需先 ollama pull 对应模型）
OLLAMA_MODEL=qwen:4b
# 强制 GPU 推理 (1=强制, 0=允许CPU回退)
OLLAMA_FORCE_GPU=1
# GPU 层数（999=全部层放GPU）
OLLAMA_NUM_GPU=999

# ================== 上下文窗口 ==================
# 小模型(4b)建议4000~6000，大模型(8b+)可提高到8000~12000
MODEL_CONTEXT_WINDOW=6000

# ================== 外部 API（可选，不用可留空）==================
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
CLAUDE_API_KEY=

# ================== 镜像源（中国大陆用户推荐）==================
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
HF_ENDPOINT=https://hf-mirror.com
